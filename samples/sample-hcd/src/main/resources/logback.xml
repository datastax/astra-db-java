<configuration scan="true">

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %magenta(%-5level) %cyan(%-30logger{30}) : %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Application logging -->
    <logger name="com.ibm.mc.demo" level="INFO" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- DataStax Astra Client logging -->
    <logger name="com.datastax.astra.client" level="INFO" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>

    <logger name="com.datastax.astra.internal" level="WARN" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- FOR logRequets() when enabled -->
    <logger name="com.datastax.astra.client.DataAPIClient" level="DEBUG" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- LangChain4j logging -->
    <logger name="dev.langchain4j" level="INFO" additivity="false">
        <appender-ref ref="STDOUT" />
    </logger>

    <!-- Root logger -->
    <root level="WARN">
        <appender-ref ref="STDOUT" />
    </root>
    
</configuration>
